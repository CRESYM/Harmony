            "converter_params": [
                314.1592653589793, 0.0, 0.0, 0.0, 326600.0, 0.0, 640000.0,
                0.0529, 0.1663, 0.0017568, 36.0, 0.01, 10.0, 0.0
            ],
            "controller_params": [
                0,
                0,
                1, 0, 0.000257, 0.0032, 1, 100000000.0,
                0,
                0,
                0,
                0,
                1, 0, 48.0, 480.0, 2, 0.0, 0.0,
                0,
                0
            ],
            "connected_buses": [
                { "bus_id": "AC1", "terminal": 1 },
                { "bus_id": "DC1", "terminal": 2 }
            ],
            "enabled": true
        },
        {
            "id": "Vs_dc",
            "location": "DC1",
            "type": "dc_source",
            "pins": 2,
            "voltage": [320000.0, -320000.0],
