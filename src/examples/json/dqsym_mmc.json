            "pins": 3,
            "voltage": 326600.0,
            "values": [0.0],
            "connected_buses": [
                { "bus_id": "AC1", "terminal": 1 },
                { "bus_id": "gnd", "terminal": 2 }
            ],
            "enabled": true
        }
    ],
    "computations": [
        { "type": "print_connections" },
        {
            "type": "dqsym",
            "dt": 2.0e-5,
            "t_start": 0.0,
