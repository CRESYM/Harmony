{
    "simulation": {
        "title": "passives_rlc",
        "description": "RLC passives network derived from example_constructors / basic element demos.",
        "output_directory": "./files",
        "frequency_range": { "start": 10, "end": 10000, "points": 15 }
    },
    "buses": [
        { "id": "bus1", "location": "AC1", "pins": 1, "enabled": true },
        { "id": "bus2", "location": "AC1", "pins": 1, "enabled": true },
        { "id": "gnd", "location": "AC1", "pins": 1, "enabled": true }
    ],
    "components": [
        {
            "id": "R1",
            "location": "AC1",
            "type": "resistor",
            "pins": 1,
            "values": [10.0],
            "connected_buses": [
                { "bus_id": "bus1", "terminal": 1 },
                { "bus_id": "bus2", "terminal": 2 }
            ],
            "enabled": true
        },
        {
            "id": "L1",
            "location": "AC1",
            "type": "inductor",
            "pins": 1,
            "values": [0.001],
            "connected_buses": [
                { "bus_id": "bus2", "terminal": 1 },
                { "bus_id": "gnd", "terminal": 2 }
            ],
            "enabled": true
        },
        {
            "id": "C1",
            "location": "AC1",
            "type": "capacitor",
            "pins": 1,
            "values": [1e-6],
            "connected_buses": [
                { "bus_id": "bus2", "terminal": 1 },
                { "bus_id": "gnd", "terminal": 2 }
            ],
            "enabled": true
        }
    ],
    "computations": [
        { "type": "print_connections" },
        { "type": "y_matrix", "component_id": "R1", "plot": true }
    ]
}
